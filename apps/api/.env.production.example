# Database
DATABASE_URL=postgresql://nexohub:PASSWORD@postgres:5432/nexohub_crm

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Secrets (GENERAR VALORES SEGUROS)
JWT_ACCESS_SECRET=CAMBIAR_POR_SECRETO_SEGURO_64_CARACTERES
JWT_REFRESH_SECRET=CAMBIAR_POR_OTRO_SECRETO_SEGURO_64_CARACTERES
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Application
NODE_ENV=production
PORT=3000
API_PREFIX=api

# CORS (dominio del frontend)
CORS_ORIGIN=https://app.tudominio.com

# Audit System
AUDIT_ENABLED=true

# File Upload
MAX_FILE_SIZE=10485760

# Email (opcional - configurar si usas notificaciones)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-email@gmail.com
# SMTP_PASS=tu-app-password
# SMTP_FROM=noreply@tudominio.com
