generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CaseStatus {
  IMPORTED
  ASSIGNED
  OBJECTED
  IN_PROGRESS
  COMPLETED
  PENDING_BILLING_REVIEW
  READY_TO_INVOICE
  INVOICED
  CLOSED
}

enum SurchargeStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String    @map("password_hash")
  name              String
  isActive          Boolean   @default(true) @map("is_active")
  deletedAt         DateTime? @map("deleted_at")
  deletedBy         String?   @map("deleted_by")
  scheduledDeleteAt DateTime? @map("scheduled_delete_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  userRoles            UserRole[]
  refreshTokens        RefreshToken[]
  createdCases         Case[]                 @relation("CaseCreator")
  assignedCases        Case[]                 @relation("CaseAssignee")
  assignmentsFrom      CaseAssignment[]       @relation("AssignmentFrom")
  assignmentsTo        CaseAssignment[]       @relation("AssignmentTo")
  caseNotes            CaseNote[]
  requestedSurcharges  Surcharge[]            @relation("SurchargeRequester")
  decidedSurcharges    Surcharge[]            @relation("SurchargeDecider")
  attachments          Attachment[]
  issuedInvoices       Invoice[]
  createdImportJobs    ImportJob[]
  auditLogs            AuditLog[]

  @@index([deletedAt])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")
  family    String?  @map("family")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([family])
  @@map("refresh_tokens")
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String
  userAgent String   @map("user_agent")
  success   Boolean
  userId    String?  @map("user_id")
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([ip])
  @@index([createdAt])
  @@index([success])
  @@map("login_attempts")
}

model Insurer {
  id                String    @id @default(cuid())
  key               String    @unique
  name              String
  deletedAt         DateTime? @map("deleted_at")
  deletedBy         String?   @map("deleted_by")
  scheduledDeleteAt DateTime? @map("scheduled_delete_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  cases      Case[]
  invoices   Invoice[]
  importJobs ImportJob[]

  @@index([deletedAt])
  @@map("insurers")
}

model Provider {
  id                String    @id @default(cuid())
  name              String
  type              String?
  deletedAt         DateTime? @map("deleted_at")
  deletedBy         String?   @map("deleted_by")
  scheduledDeleteAt DateTime? @map("scheduled_delete_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  cases Case[]

  @@index([name])
  @@index([type])
  @@index([deletedAt])
  @@map("providers")
}

model Customer {
  id                String    @id @default(cuid())
  name              String
  email             String?
  phone             String?
  address           String?
  deletedAt         DateTime? @map("deleted_at")
  deletedBy         String?   @map("deleted_by")
  scheduledDeleteAt DateTime? @map("scheduled_delete_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  cases Case[]

  @@index([phone])
  @@index([email])
  @@index([name])
  @@index([deletedAt])
  @@map("customers")
}

model Vehicle {
  id                String    @id @default(cuid())
  make              String?
  model             String?
  year              Int?
  plate             String?
  color             String?
  weight            String?
  usageType         String?   @map("usage_type")
  deletedAt         DateTime? @map("deleted_at")
  deletedBy         String?   @map("deleted_by")
  scheduledDeleteAt DateTime? @map("scheduled_delete_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  cases Case[]

  @@index([plate])
  @@index([deletedAt])
  @@map("vehicles")
}

model Case {
  id                       String    @id @default(cuid())
  insurerId                String    @map("insurer_id")
  externalId               String    @map("external_id")
  externalSeq              String?   @map("external_seq")
  serviceType              String?   @map("service_type")
  serviceStatusRaw         String?   @map("service_status_raw")
  openedAt                 DateTime? @map("opened_at")
  productCode              String?   @map("product_code")
  policyNumber             String?   @map("policy_number")
  certificate              String?
  customerId               String?   @map("customer_id")
  vehicleId                String?   @map("vehicle_id")
  originDescription        String?   @map("origin_description")
  originProvince           String?   @map("origin_province")
  originLocality           String?   @map("origin_locality")
  destinationDescription   String?   @map("destination_description")
  destinationProvince      String?   @map("destination_province")
  destinationLocality      String?   @map("destination_locality")
  kmToOrigin               Float?    @map("km_to_origin")
  kmOriginToDestination    Float?    @map("km_origin_to_destination")
  providerId               String?   @map("provider_id")
  driverName               String?   @map("driver_name")
  serviceVehicleMake       String?   @map("service_vehicle_make")
  serviceVehicleModel      String?   @map("service_vehicle_model")
  serviceVehicleType       String?   @map("service_vehicle_type")
  serviceVehiclePlate      String?   @map("service_vehicle_plate")
  serviceVehicleColor      String?   @map("service_vehicle_color")
  autoAssignedProvider     String?   @map("auto_assigned_provider")
  createdByUsernameRaw     String?   @map("created_by_username_raw")
  tInterventionAt          DateTime? @map("t_intervention_at")
  tAssignedAt              DateTime? @map("t_assigned_at")
  tAcceptedAt              DateTime? @map("t_accepted_at")
  tLocatedAt               DateTime? @map("t_located_at")
  tStartedAt               DateTime? @map("t_started_at")
  tFinishedAt              DateTime? @map("t_finished_at")
  tClosedAt                DateTime? @map("t_closed_at")
  priceInitialCents        Int?      @map("price_initial_cents")
  priceSubtotalCents       Int?      @map("price_subtotal_cents")
  taxApplicable            Boolean?  @map("tax_applicable")
  taxAmountCents           Int?      @map("tax_amount_cents")
  insurerAmountCents       Int?      @map("insurer_amount_cents")
  customerExcessCents      Int?      @map("customer_excess_cents")
  customerManiobraCents    Int?      @map("customer_maniobra_cents")
  priceBaseCents           Int?      @map("price_base_cents")
  surchargeAmountCents     Int?      @default(0) @map("surcharge_amount_cents")
  priceFinalCents          Int?      @map("price_final_cents")
  coverageText             String?   @map("coverage_text")
  requestedByApp           Boolean?  @map("requested_by_app")
  status                   CaseStatus @default(IMPORTED)
  assignedToUserId         String?   @map("assigned_to_user_id")
  lockedAt                 DateTime? @map("locked_at")
  technicianRequestedAmountCents Int? @map("technician_requested_amount_cents")
  technicianRequestedSurchargeCents Int? @map("technician_requested_surcharge_cents")
  technicianRejectionReason String? @map("technician_rejection_reason")
  technicianRejectedBy     String?   @map("technician_rejected_by")
  technicianRejectedAt     DateTime? @map("technician_rejected_at")
  technicianRejectionStatus String? @map("technician_rejection_status")
  isBackdated              Boolean?  @default(false) @map("is_backdated")
  createdById              String?   @map("created_by_id")
  deletedAt                DateTime? @map("deleted_at")
  deletedById              String?   @map("deleted_by_id")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  insurer          Insurer             @relation(fields: [insurerId], references: [id])
  customer         Customer?           @relation(fields: [customerId], references: [id])
  vehicle          Vehicle?            @relation(fields: [vehicleId], references: [id])
  provider         Provider?           @relation(fields: [providerId], references: [id])
  assignedToUser   User?               @relation("CaseAssignee", fields: [assignedToUserId], references: [id])
  createdBy        User?               @relation("CaseCreator", fields: [createdById], references: [id])
  assignments      CaseAssignment[]
  notes            CaseNote[]
  caseAttachments  CaseAttachment[]
  surcharges       Surcharge[]
  invoiceLines     InvoiceLine[]
  importRows       ImportRow[]

  @@unique([insurerId, externalId, externalSeq])
  @@index([insurerId])
  @@index([status])
  @@index([assignedToUserId])
  @@index([openedAt])
  @@map("cases")
}

model CaseAssignment {
  id         String   @id @default(cuid())
  caseId     String   @map("case_id")
  fromUserId String?  @map("from_user_id")
  toUserId   String   @map("to_user_id")
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at")

  case     Case  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  fromUser User? @relation("AssignmentFrom", fields: [fromUserId], references: [id])
  toUser   User  @relation("AssignmentTo", fields: [toUserId], references: [id])

  @@map("case_assignments")
}

model CaseNote {
  id        String   @id @default(cuid())
  caseId    String   @map("case_id")
  authorId  String   @map("author_id")
  note      String
  createdAt DateTime @default(now()) @map("created_at")

  case   Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@map("case_notes")
}

model Attachment {
  id         String   @id @default(cuid())
  ownerId    String   @map("owner_id")
  fileName   String   @map("file_name")
  mimeType   String   @map("mime_type")
  size       Int
  storageKey String   @map("storage_key")
  createdAt  DateTime @default(now()) @map("created_at")

  owner           User             @relation(fields: [ownerId], references: [id])
  caseAttachments CaseAttachment[]
  surcharges      Surcharge[]

  @@map("attachments")
}

model CaseAttachment {
  caseId       String @map("case_id")
  attachmentId String @map("attachment_id")

  case       Case       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@id([caseId, attachmentId])
  @@map("case_attachments")
}

model Surcharge {
  id                    String    @id @default(cuid())
  caseId                String    @map("case_id")
  concept               String
  description           String
  amountCents           Int       @map("amount_cents")
  currency              String    @default("USD")
  evidenceAttachmentId  String?   @map("evidence_attachment_id")
  status                SurchargeStatus @default(DRAFT)
  requestedById         String    @map("requested_by_id")
  requestedAt           DateTime  @default(now()) @map("requested_at")
  decidedById           String?   @map("decided_by_id")
  decidedAt             DateTime? @map("decided_at")
  decisionReason        String?   @map("decision_reason")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  case              Case        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  requestedBy       User        @relation("SurchargeRequester", fields: [requestedById], references: [id])
  decidedBy         User?       @relation("SurchargeDecider", fields: [decidedById], references: [id])
  evidenceAttachment Attachment? @relation(fields: [evidenceAttachmentId], references: [id])

  @@index([caseId])
  @@index([status])
  @@map("surcharges")
}

model Invoice {
  id          String    @id @default(cuid())
  insurerId   String    @map("insurer_id")
  periodStart DateTime  @map("period_start")
  periodEnd   DateTime  @map("period_end")
  status      InvoiceStatus @default(DRAFT)
  issuedAt    DateTime? @map("issued_at")
  issuedById  String?   @map("issued_by_id")
  totalCents  Int       @default(0) @map("total_cents")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  insurer      Insurer       @relation(fields: [insurerId], references: [id])
  issuedBy     User?         @relation(fields: [issuedById], references: [id])
  invoiceLines InvoiceLine[]

  @@index([insurerId])
  @@index([status])
  @@map("invoices")
}

model InvoiceLine {
  id                 String @id @default(cuid())
  invoiceId          String @map("invoice_id")
  caseId             String @unique @map("case_id")
  baseAmountCents    Int    @map("base_amount_cents")
  surchargeTotalCents Int   @map("surcharge_total_cents")
  taxCents           Int    @map("tax_cents")
  totalCents         Int    @map("total_cents")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  case    Case    @relation(fields: [caseId], references: [id])

  @@map("invoice_lines")
}

model ImportJob {
  id         String    @id @default(cuid())
  insurerId  String    @map("insurer_id")
  fileName   String    @map("file_name")
  sha256     String
  status     String    @default("PENDING")
  startedAt  DateTime? @map("started_at")
  finishedAt DateTime? @map("finished_at")
  createdById String   @map("created_by_id")
  statsJson  String?   @map("stats_json")
  createdAt  DateTime  @default(now()) @map("created_at")

  insurer    Insurer     @relation(fields: [insurerId], references: [id])
  createdBy  User        @relation(fields: [createdById], references: [id])
  importRows ImportRow[]

  @@index([insurerId])
  @@index([status])
  @@map("import_jobs")
}

model ImportRow {
  id          String  @id @default(cuid())
  importJobId String  @map("import_job_id")
  rowNumber   Int     @map("row_number")
  externalId  String? @map("external_id")
  caseId      String? @map("case_id")
  action      String
  errorsJson  String? @map("errors_json")
  rawJson     String  @map("raw_json")

  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  case      Case?     @relation(fields: [caseId], references: [id])

  @@index([importJobId])
  @@map("import_rows")
}

model AuditLog {
  id           String   @id @default(cuid())
  requestId    String?  @map("request_id")
  actorId      String?  @map("actor_id")
  actorEmail   String?  @map("actor_email")
  actorName    String?  @map("actor_name")
  actorRole    String?  @map("actor_role")
  eventType    String   @map("event_type")
  entityType   String   @map("entity_type")
  entityId     String?  @map("entity_id")
  action       String
  status       String   @default("SUCCESS")
  message      String?
  details      String?
  beforeJson   String?  @map("before_json")
  afterJson    String?  @map("after_json")
  metadataJson String?  @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id])

  @@index([requestId])
  @@index([eventType])
  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@index([action])
  @@index([status])
  @@map("audit_log")
}
