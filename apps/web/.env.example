# Variables de entorno para Frontend (Producción)

# URL de la API (en producción usa proxy, no se necesita)
VITE_API_URL=/api

# Configuración de timeouts (milisegundos)
VITE_API_TIMEOUT=30000
VITE_API_RETRY_DELAY=1000
VITE_API_RETRY_COUNT=3

# Configuración de notificaciones
VITE_ENABLE_ERROR_NOTIFICATIONS=true
VITE_ENABLE_SERVICE_UNAVAILABLE_NOTIFICATIONS=true

# Configuración de caché
VITE_CACHE_TTL=300000

# Configuración de logging
VITE_LOG_LEVEL=error

# Configuración de feature flags
VITE_ENABLE_DEBUG_MODE=false
VITE_ENABLE_PERFORMANCE_MONITORING=false
